# serializer version: 1
# name: TestLibretroGeneratorOpera.test_generate
  tuple(
    list([
      '/usr/bin/retroarch',
      '-L',
      '/usr/lib/libretro/opera_libretro.so',
      '--config',
      '/userdata/system/configs/retroarch/retroarchcustom.cfg',
      '--verbose',
      '/userdata/roms/3do/rom.iso',
    ]),
    dict({
      'XDG_CONFIG_HOME': '/userdata/system/configs',
    }),
  )
