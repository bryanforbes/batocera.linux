# serializer version: 1
# name: TestLibretroGeneratorScummVM.test_generate
  tuple(
    list([
      '/usr/bin/retroarch',
      '-L',
      '/usr/lib/libretro/scummvm_libretro.so',
      '--config',
      '/userdata/system/configs/retroarch/retroarchcustom.cfg',
      '--verbose',
      '/userdata/roms/scummvm/rom',
    ]),
    dict({
      'XDG_CONFIG_HOME': '/userdata/system/configs',
    }),
  )
