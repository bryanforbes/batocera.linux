# serializer version: 1
# name: TestLibretroGeneratorDosboxPure.test_generate
  tuple(
    list([
      '/usr/bin/retroarch',
      '-L',
      '/usr/lib/libretro/dosbox_pure_libretro.so',
      '--config',
      '/userdata/system/configs/retroarch/retroarchcustom.cfg',
      '/userdata/roms/dos/rom.pc',
      '--verbose',
    ]),
    dict({
      'XDG_CONFIG_HOME': '/userdata/system/configs',
    }),
  )
# ---
