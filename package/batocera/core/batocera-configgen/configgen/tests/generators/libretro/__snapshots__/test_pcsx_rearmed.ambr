# serializer version: 1
# name: TestLibretroGeneratorPCSXRearmed.test_generate
  tuple(
    list([
      '/usr/bin/retroarch',
      '-L',
      '/usr/lib/libretro/pcsx_rearmed_libretro.so',
      '--config',
      '/userdata/system/configs/retroarch/retroarchcustom.cfg',
      '--verbose',
      '/userdata/roms/psx/rom.cue',
    ]),
    dict({
      'XDG_CONFIG_HOME': '/userdata/system/configs',
    }),
  )
