# name: TestRpcs3Generator.test_generate_firmware[\nfoo:bar:baz\nspam:ham:bam\n-False]
  tuple(
    list([
      '/usr/bin/rpcs3',
      '/userdata/roms/ps3/rom_dir/PS3_GAME/USRDIR/EBOOT.BIN',
      '--no-gui',
    ]),
    dict({
      'QT_QPA_PLATFORM': 'xcb',
      'SDL_GAMECONTROLLERCONFIG': '030000005e0400000a0b000005040000,real name 1,platform:Linux,b:b0,a:b1,dpdown:h0.4,leftx:a0,lefty:a1,rightx:a2,righty:a3,lefttrigger:b6,leftstick:b11,dpleft:h0.8,rightshoulder:b5,leftshoulder:b4,righttrigger:b7,rightstick:b12,dpright:h0.2,back:b8,start:b9,dpup:h0.1,y:b2,x:b3,',
      'SDL_JOYSTICK_HIDAPI': '0',
      'XDG_CACHE_HOME': '/userdata/system/cache',
      'XDG_CONFIG_HOME': '/userdata/system/configs',
    }),
  )
