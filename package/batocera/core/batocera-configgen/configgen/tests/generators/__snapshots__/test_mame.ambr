# ---
# name: test_generate_pads_config
  '''
  <?xml version="1.0" ?>
  <mameconfig version="10">
  	<system name="default">
  		<crosshairs>
  			<crosshair player="0" mode="0"/>
  			<crosshair player="1" mode="0"/>
  			<crosshair player="2" mode="0"/>
  			<crosshair player="3" mode="0"/>
  		</crosshairs>
  		<input>
  			<port tag=":mainpcb:ANALOG1" type="P1_AD_STICK_X" mask="255" defvalue="128">
  				<newseq type="standard">GUNCODE_1_XAXIS</newseq>
  			</port>
  			<port tag=":mainpcb:ANALOG2" type="P1_AD_STICK_Y" mask="255" defvalue="128">
  				<newseq type="standard">GUNCODE_1_YAXIS</newseq>
  			</port>
  			<port type="P1_JOYSTICK_UP">
  				<newseq type="standard">JOYCODE_1_YAXIS_UP_SWITCH OR JOYCODE_1_HAT1UP</newseq>
  			</port>
  			<port type="P1_JOYSTICK_DOWN">
  				<newseq type="standard">JOYCODE_1_YAXIS_DOWN_SWITCH OR JOYCODE_1_HAT1DOWN</newseq>
  			</port>
  			<port type="P1_JOYSTICK_LEFT">
  				<newseq type="standard">JOYCODE_1_XAXIS_LEFT_SWITCH OR JOYCODE_1_HAT1LEFT</newseq>
  			</port>
  			<port type="P1_JOYSTICK_RIGHT">
  				<newseq type="standard">JOYCODE_1_XAXIS_RIGHT_SWITCH OR JOYCODE_1_HAT1RIGHT</newseq>
  			</port>
  			<port type="P1_JOYSTICKLEFT_UP">
  				<newseq type="standard">JOYCODE_1_YAXIS_UP_SWITCH OR JOYCODE_1_HAT1UP</newseq>
  			</port>
  			<port type="P1_JOYSTICKLEFT_DOWN">
  				<newseq type="standard">JOYCODE_1_YAXIS_DOWN_SWITCH OR JOYCODE_1_HAT1DOWN</newseq>
  			</port>
  			<port type="P1_JOYSTICKLEFT_LEFT">
  				<newseq type="standard">JOYCODE_1_XAXIS_LEFT_SWITCH OR JOYCODE_1_HAT1LEFT</newseq>
  			</port>
  			<port type="P1_JOYSTICKLEFT_RIGHT">
  				<newseq type="standard">JOYCODE_1_XAXIS_RIGHT_SWITCH OR JOYCODE_1_HAT1RIGHT</newseq>
  			</port>
  			<port type="P1_JOYSTICKRIGHT_UP">
  				<newseq type="standard">JOYCODE_1_RYAXIS_NEG_SWITCH OR JOYCODE_1_BUTTON3</newseq>
  			</port>
  			<port type="P1_JOYSTICKRIGHT_DOWN">
  				<newseq type="standard">JOYCODE_1_RYAXIS_POS_SWITCH OR JOYCODE_1_BUTTON2</newseq>
  			</port>
  			<port type="P1_JOYSTICKRIGHT_LEFT">
  				<newseq type="standard">JOYCODE_1_RXAXIS_NEG_SWITCH OR JOYCODE_1_BUTTON4</newseq>
  			</port>
  			<port type="P1_JOYSTICKRIGHT_RIGHT">
  				<newseq type="standard">JOYCODE_1_RXAXIS_POS_SWITCH OR JOYCODE_1_BUTTON1</newseq>
  			</port>
  			<port type="P1_BUTTON1">
  				<newseq type="standard">JOYCODE_1_BUTTON2</newseq>
  			</port>
  			<port type="P1_BUTTON2">
  				<newseq type="standard">JOYCODE_1_BUTTON1</newseq>
  			</port>
  			<port type="P1_BUTTON3">
  				<newseq type="standard">JOYCODE_1_BUTTON4</newseq>
  			</port>
  			<port type="P1_BUTTON4">
  				<newseq type="standard">JOYCODE_1_BUTTON3</newseq>
  			</port>
  			<port type="P1_BUTTON5">
  				<newseq type="standard">JOYCODE_1_BUTTON5</newseq>
